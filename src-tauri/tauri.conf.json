{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AP Wiki",
  "version": "0.1.0",
  "identifier": "com.apwiki.desktop",
  "mainBinaryName": "APWikiDesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AP Wiki",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
